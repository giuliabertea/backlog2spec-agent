{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",

  "parameters": {
    "prefix": {
      "type": "string",
      "minLength": 3,
      "maxLength": 16,
      "metadata": {
        "description": "Short lowercase prefix used for every resource name (3–16 chars, letters and hyphens only). Example: b2s or myteam-b2s."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources. GPT-4o is available in: eastus, eastus2, swedencentral, australiaeast, westus, westus3."
      }
    },
    "gptModelVersion": {
      "type": "string",
      "defaultValue": "2024-11-20",
      "metadata": {
        "description": "GPT-4o model version to deploy. Check https://learn.microsoft.com/azure/ai-services/openai/concepts/models for available versions per region."
      }
    },
    "gptCapacityK": {
      "type": "int",
      "defaultValue": 30,
      "minValue": 1,
      "maxValue": 450,
      "metadata": {
        "description": "GPT-4o provisioned throughput in thousands of tokens per minute (TPM). Increase if you hit rate limits."
      }
    },
    "searchSku": {
      "type": "string",
      "defaultValue": "basic",
      "allowedValues": [ "free", "basic", "standard" ],
      "metadata": {
        "description": "Azure AI Search pricing tier. 'free' allows 1 instance per subscription with 50 MB storage — sufficient for small repos. Use 'basic' or 'standard' for larger codebases or production use."
      }
    }
  },

  "variables": {
    "aiServicesName": "[concat(parameters('prefix'), '-ai')]",
    "searchName":     "[concat(parameters('prefix'), '-search')]",
    "hubName":        "[concat(parameters('prefix'), '-hub')]",
    "projectName":    "[concat(parameters('prefix'), '-project')]",
    "storageName":    "[concat(toLower(replace(parameters('prefix'), '-', '')), 'st')]",
    "keyVaultName":   "[concat(parameters('prefix'), '-kv')]",
    "gptDeployment":  "gpt-4o"
  },

  "resources": [

    {
      "comments": "Storage account — required dependency for Azure AI Foundry hub.",
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[variables('storageName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Standard_LRS" },
      "kind": "StorageV2",
      "properties": {
        "accessTier": "Hot",
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      }
    },

    {
      "comments": "Key Vault — required dependency for Azure AI Foundry hub.",
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('keyVaultName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": { "family": "A", "name": "standard" },
        "tenantId": "[subscription().tenantId]",
        "accessPolicies": [],
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 7
      }
    },

    {
      "comments": "Azure AI Services account — provides the OpenAI-compatible endpoint for GPT-4o and the Assistants API used by Backlog2SpecAgent.",
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('aiServicesName')]",
      "location": "[parameters('location')]",
      "kind": "AIServices",
      "sku": { "name": "S0" },
      "properties": {
        "publicNetworkAccess": "Enabled",
        "customSubDomainName": "[variables('aiServicesName')]"
      }
    },

    {
      "comments": "GPT-4o model deployment — used for both the direct LLM path and Foundry Agent mode.",
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2023-05-01",
      "name": "[concat(variables('aiServicesName'), '/', variables('gptDeployment'))]",
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]"
      ],
      "sku": {
        "name": "Standard",
        "capacity": "[parameters('gptCapacityK')]"
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "gpt-4o",
          "version": "[parameters('gptModelVersion')]"
        },
        "versionUpgradeOption": "OnceNewDefaultVersionAvailable",
        "raiPolicyName": "Microsoft.DefaultV2"
      }
    },

    {
      "comments": "Azure AI Foundry hub — workspace container that links AI services and hosts projects.",
      "type": "Microsoft.MachineLearningServices/workspaces",
      "apiVersion": "2024-04-01",
      "name": "[variables('hubName')]",
      "location": "[parameters('location')]",
      "kind": "Hub",
      "identity": { "type": "SystemAssigned" },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]"
      ],
      "properties": {
        "friendlyName": "[concat(parameters('prefix'), ' Hub')]",
        "storageAccount": "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]",
        "keyVault": "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]",
        "hbiWorkspace": false,
        "publicNetworkAccess": "Enabled"
      }
    },

    {
      "comments": "Connection that wires the AI Services account (and its GPT-4o deployment) into the Foundry hub so projects can call the model and create agents.",
      "type": "Microsoft.MachineLearningServices/workspaces/connections",
      "apiVersion": "2024-04-01",
      "name": "[concat(variables('hubName'), '/ai-services-connection')]",
      "dependsOn": [
        "[resourceId('Microsoft.MachineLearningServices/workspaces', variables('hubName'))]"
      ],
      "properties": {
        "category": "AIServices",
        "target": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), '2023-05-01').endpoint]",
        "authType": "ApiKey",
        "isSharedToAll": true,
        "credentials": {
          "key": "[listKeys(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), '2023-05-01').key1]"
        },
        "metadata": {
          "ApiType": "Azure",
          "ResourceId": "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]"
        }
      }
    },

    {
      "comments": "Azure AI Foundry project — where agents are created, managed, and called at runtime.",
      "type": "Microsoft.MachineLearningServices/workspaces",
      "apiVersion": "2024-04-01",
      "name": "[variables('projectName')]",
      "location": "[parameters('location')]",
      "kind": "Project",
      "identity": { "type": "SystemAssigned" },
      "dependsOn": [
        "[resourceId('Microsoft.MachineLearningServices/workspaces', variables('hubName'))]",
        "[resourceId('Microsoft.MachineLearningServices/workspaces/connections', variables('hubName'), 'ai-services-connection')]"
      ],
      "properties": {
        "friendlyName": "[concat(parameters('prefix'), ' Project')]",
        "hubResourceId": "[resourceId('Microsoft.MachineLearningServices/workspaces', variables('hubName'))]",
        "hbiWorkspace": false,
        "publicNetworkAccess": "Enabled"
      }
    },

    {
      "comments": "Azure AI Search service — hosts the repo-context index used by Phase 3 RAG. Run scripts/index-repo.ps1 to populate it.",
      "type": "Microsoft.Search/searchServices",
      "apiVersion": "2023-11-01",
      "name": "[variables('searchName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "[parameters('searchSku')]" },
      "properties": {
        "replicaCount": 1,
        "partitionCount": 1,
        "hostingMode": "default",
        "publicNetworkAccess": "enabled"
      }
    }

  ],

  "outputs": {
    "aiServicesEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), '2023-05-01').endpoint]",
      "metadata": { "description": "Use this as AzureAI:Endpoint in dotnet user-secrets." }
    },
    "aiServicesKey": {
      "type": "string",
      "value": "[listKeys(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), '2023-05-01').key1]",
      "metadata": { "description": "Use this as AzureAI:ApiKey in dotnet user-secrets." }
    },
    "gptDeploymentName": {
      "type": "string",
      "value": "[variables('gptDeployment')]",
      "metadata": { "description": "Use this as AzureAI:DeploymentName in dotnet user-secrets." }
    },
    "searchEndpoint": {
      "type": "string",
      "value": "[concat('https://', variables('searchName'), '.search.windows.net')]",
      "metadata": { "description": "Use this as -SearchUrl when running scripts/index-repo.ps1." }
    },
    "searchAdminKey": {
      "type": "string",
      "value": "[listAdminKeys(resourceId('Microsoft.Search/searchServices', variables('searchName')), '2023-11-01').primaryKey]",
      "metadata": { "description": "Use this as -SearchKey when running scripts/index-repo.ps1." }
    },
    "foundryProjectName": {
      "type": "string",
      "value": "[variables('projectName')]",
      "metadata": { "description": "Open ai.azure.com, select this project, then go to Agents to create the backlog2spec-agent." }
    }
  }
}
